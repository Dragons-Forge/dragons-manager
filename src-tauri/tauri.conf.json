{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MultiRoblox Manager",
  "version": "1.0.0",
  "identifier": "com.well2.multiroblox-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MultiRoblox Manager",
        "width": 1280,
        "height": 720,
        "minWidth": 1280,
        "minHeight": 720,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
